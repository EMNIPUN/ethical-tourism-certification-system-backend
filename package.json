  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node tests/testConfirmationFlow.js",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:api": "cypress run --spec \"cypress/e2e/api/**/*.cy.js\"",
    "cy:run:bdd": "cypress run --spec \"cypress/e2e/**/*.feature\"",
    "cy:run:all": "npm run cy:run:api && npm run cy:run:bdd",
    "cy:report:open": "start cypress\\reports\\mochawesome\\index.html",
    "cy:run:api:report": "npm run cy:run:api && npm run cy:report:open",
    "cy:run:all:report": "npm run cy:run:all && npm run cy:report:open",
    "test:e2e": "npm run cy:run:api"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^3.0.3",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "inquirer": "^13.2.2",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.11.0",
    "mongoose": "^9.1.6",
    "multer": "^2.0.2",
    "openai": "^6.25.0",
    "ora": "^9.3.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "serpapi": "^2.2.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
