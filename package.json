    "cypress": "^14.5.1",
    "cypress-mochawesome-reporter": "^4.0.2",
    "esbuild": "^0.25.10",
    "mocha-junit-reporter": "^2.2.1",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^5.0.0",
    "mochawesome-report-generator": "^6.2.0",
    "nodemon": "^3.1.11"
